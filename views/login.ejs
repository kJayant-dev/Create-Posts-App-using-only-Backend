<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login</title>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; font-family: sans-serif; }
        body { background-color: #18181b; color: white; }
        .main-container { width: 100%; min-height: 100vh; padding: 2.5rem; }
        .heading { font-size: 1.875rem; margin-bottom: 1.25rem; }
        .form-container { display: flex; flex-direction: column; width: 300px; gap: 1rem; }
        .input-field { padding: 0.5rem 0.75rem; outline: none; background: transparent; border: 2px solid #27272a; border-radius: 0.375rem; color: white; }
        .submit-btn { padding: 0.5rem 1.25rem; width: max-content; background-color: #3b82f6; border: none; border-radius: 0.375rem; color: white; cursor: pointer; font-size: 1rem; }
    </style>
</head>
<body>
    <div class="main-container">
        <h3 class="heading">Login Your Account</h3>
        <form action="/login" method="post" class="form-container">
            <input type="email" placeholder="Email" name="email" class="input-field">
            <input type="password" placeholder="Password" name="password" class="input-field">
            <input type="submit" value="Login Account" class="submit-btn">
        </form>
    </div>
</body>
</html>